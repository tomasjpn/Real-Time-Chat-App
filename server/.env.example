# Database Configuration
DATABASE_URL_CONNECTION_STRING=postgres://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:<DB_PORT>/<DB_NAME>
DB_HOST=<DB_HOST>
DB_PORT=<DB_PORT>
DB_USER=<DB_USER>
DB_PASSWORD=<DB_PASSWORD>
DB_NAME=<DB_NAME>

# App server (Fastify) — 0.0.0.0 so other devices on the LAN can reach it
APP_HOST=0.0.0.0
APP_PORT=3000

# Comma-separated list of allowed origins for CORS + Socket.IO.
# Add your machine's LAN IP (e.g. http://192.168.1.23:5173) so phones/other
# devices on the same network can connect to the frontend dev server.
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
